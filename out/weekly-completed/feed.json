            \n                    <b><br></b> \n                    <span class=\"browsers\">Added to <strong>Firefox</strong></span> \n                    <b>&nbsp;➞&nbsp;</b>\n                    <span class=\"ni3 engines\"><strong>3 of 3</strong> engines</span>\n\n                  </li>\n                  <li>\n                      <span>css ➞ properties ➞ baseline-shift ➞ super\n                      \t<a href=\"https://drafts.csswg.org/css-inline-3/#valdef-baseline-shift-super\"><img src=\"https://bcd-watch.igalia.com/imgs/spec2.svg\" alt=\"Spec link\"></a>\n                      </span>\n\n          \n\n                    \n                    <b><br></b> \n                    <span class=\"browsers\">Added to <strong>Firefox</strong></span> \n                    <b>&nbsp;➞&nbsp;</b>\n                    <span class=\"ni3 engines\"><strong>3 of 3</strong> engines</span>\n\n                  </li>\n              </ol>\n          </section>\n\n  <hr>\n  <ul id=\"prev-next\">\n  \t<li>Previous report: <a href=\"\"><time title=\"Monday, 23 February 2026\">Monday, 23 February 2026</time></a></li>\n  </ul>\n  <hr>\n  <footer>\n  \t<p>\n  \t<a href=\"https://bcd-watch.igalia.com/\">BCD Watch</a>: A service of <a href=\"https://igalia.com\"><img src=\"https://bcd-watch.igalia.com/imgs/igalia-logo.png\" alt=\"Igalia\"></a>\n  \t</p>\n  \t<p>\n  \tSubscribe: <a href=\"feed.rss\">RSS</a> • <a href=\"feed.atom\">Atom</a> • <a href=\"feed.json\">JSON</a>\n  \t</p>\n\t\t<div class=\"subfooter\">\n\t\t\t<span class=\"details\">\n\t\t\tThis report was generated by diffing <a href=\"https://github.com/mdn/browser-compat-data/releases/tag/v7.3.3\">v7.3.3</a> <small>(Friday, 20 February 2026)</small> and <a href=\"https://github.com/mdn/browser-compat-data/releases/tag/v7.3.5\">v7.3.5</a> <small>(Friday, 27 February 2026)</small>\n\t\t\t</span>\n\t\t</div>\n  </footer>\n  </main>",
